  "styles": {
    "blocks": {
      "core/avatar": {
        "border": {
          "radius": "60px"
        }
      },
      "core/button": {
        "css": "transition: all 0.2s ease-in-out;",
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)"
        },
        "variations": {
          "fill": {
            "border": {
              "width": "1px"
            },
            "spacing": {
              "padding": {
                "bottom": "calc(0.6rem - 1px)",
                "left": "calc(1rem - 1px)",
                "right": "calc(1rem - 1px)",
                "top": "calc(0.6rem - 1px)"
              }
            }
          },
          "outline": {
            "border": {
              "color": "var(--wp--preset--color--brand)",
              "width": "1px"
            },
            "color": {
              "background": "var(--wp--preset--color--transparent)",
              "text": "var(--wp--preset--color--base-900)"
            },
            "spacing": {
              "padding": {
                "bottom": "calc(0.6rem - 1px)",
                "left": "calc(1rem - 1px)",
                "right": "calc(1rem - 1px)",
                "top": "calc(0.6rem - 1px)"
              }
            }
          }
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "0.7rem"
        }
      },
      "core/calendar": {
        "color": {
          "text": "var(--wp--preset--color--base-900)"
        },
        "css": ".wp-block-calendar table:where(:not(.has-text-color)) th{background-color:var(--wp--preset--color--base-800);color:var(--wp--preset--color--base);border-color:var(--wp--preset--color--base-800)} & table:where(:not(.has-text-color)) td{border-color:var(--wp--preset--color--base-800)}"
      },
      "core/categories": {
        "css": "& {list-style-type:none;} & li{margin-bottom: var(--wp--preset--spacing--x-small);}",
        "spacing": {
          "padding": {
            "left": "0px",
            "right": "0px"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "400"
        }
      },
